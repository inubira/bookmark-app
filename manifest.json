{
  "manifest_version": 3,
  "name": "Yes Sales Bookmarks",
  "version": "1.2",
  "description": "Access Yes Sales company links via a streamlined popup menu in the toolbar.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Yes Sales Bookmarks"
  },
  "permissions": ["bookmarks"],
  "host_permissions": [
    "https://docs.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
